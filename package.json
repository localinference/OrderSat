{
  "name": "@localinference/order-sat",
  "type": "module",
  "version": "0.0.0",
  "description": "",
  "keywords": [
    "typescript",
    "localinference"
  ],
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/localinference/OrderSaT.git"
  },
  "bugs": {
    "url": "https://github.com/localinference/OrderSaT/issues"
  },
  "homepage": "https://localinference.org",
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "format": "prettier . --write",
    "build": "tsup",
    "test": "npm run build && node test/run-coverage.mjs && node test/e2e/run.mjs",
    "bench": "npm run build && node benchmark/bench.js",
    "prepare": "husky",
    "prepublishOnly": "npm run test && npm run bench"
  },
  "c8": {
    "all": true,
    "include": [
      "dist/**/*.js"
    ],
    "exclude": [
      "dist/**/*.d.ts",
      "test/**",
      "benchmark/**",
      "playwright.config.ts"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nodearchive/nodearchive": "^1.0.0",
    "@playwright/test": "^1.58.2",
    "@poppinss/cliui": "^6.7.0",
    "@types/node": "^25.5.0",
    "c8": "^11.0.0",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.6.3",
    "wasmagic": "^1.0.7",
    "onnxruntime-web": "^1.24.3",
    "pdfjs-dist": "^5.5.207",
    "schema-dts": "^1.1.5",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "@adobe/structured-data-validator": "^1.7.0",
    "@sctg/sentencepiece-js": "^1.3.3",
    "franc": "^6.2.0"
  },
  "dependencies": {
    "@sovereignbase/bytecodec": "^1.3.3"
  }
}
