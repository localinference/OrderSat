{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#order",
      "@type": "Order",
      "paymentMethod": "https://schema.org/Cash",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        },
        {
          "@id": "#offer-2"
        },
        {
          "@id": "#offer-3"
        },
        {
          "@id": "#offer-4"
        }
      ],
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "price": "64000"
      },
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Cash Tendered",
          "value": "100000"
        },
        {
          "@type": "PropertyValue",
          "name": "Change",
          "value": "36000"
        }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "9000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-1"
      }
    },
    {
      "@id": "#product-1",
      "@type": "Product",
      "name": "twist donut"
    },
    {
      "@id": "#offer-2",
      "@type": "Offer",
      "price": "9000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-2"
      }
    },
    {
      "@id": "#product-2",
      "@type": "Product",
      "name": "milk pastry roll"
    },
    {
      "@id": "#offer-3",
      "@type": "Offer",
      "price": "10000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-3"
      }
    },
    {
      "@id": "#product-3",
      "@type": "Product",
      "name": "[ERROR:UNCERTAIN] soft steamed chococake"
    },
    {
      "@id": "#offer-4",
      "@type": "Offer",
      "price": "9000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-4"
      }
    },
    {
      "@id": "#product-4",
      "@type": "Product",
      "name": "redbean bread"
    }
  ]
}
