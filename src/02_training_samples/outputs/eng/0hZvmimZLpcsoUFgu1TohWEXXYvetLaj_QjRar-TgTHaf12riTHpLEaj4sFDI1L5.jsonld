{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#merchant",
      "@type": "LocalBusiness",
      "name": "Ichigaya Terminal",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1-Y-X Kudan",
        "addressLocality": "Chiyoda-ku",
        "addressCountry": "Japan"
      }
    },
    {
      "@id": "#order",
      "@type": "Order",
      "seller": {
        "@id": "#merchant"
      },
      "orderNumber": "1234",
      "orderDate": "2022-11-09",
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "price": "120.80"
      },
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Receipt Type",
          "value": "Receipt"
        },
        {
          "@type": "PropertyValue",
          "name": "Registration Number",
          "value": "T0123456789012"
        },
        {
          "@type": "PropertyValue",
          "name": "Receipt Note",
          "value": "Meals, goods (reduced tax rate)"
        },
        {
          "@type": "PropertyValue",
          "name": "Tax Breakdown 8%",
          "value": "Taxable 10.00, Tax 0.80"
        },
        {
          "@type": "PropertyValue",
          "name": "Tax Breakdown 10%",
          "value": "Taxable 100.00, Tax 10.00"
        }
      ]
    }
  ]
}
