{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#order",
      "@type": "Order",
      "priceCurrency": "IDR",
      "paymentMethod": "https://schema.org/Cash",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        }
      ],
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "priceCurrency": "IDR",
        "price": "34000"
      },
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Subtotal",
          "value": "34000",
          "unitText": "IDR"
        },
        {
          "@type": "PropertyValue",
          "name": "Grand Total",
          "value": "34000",
          "unitText": "IDR"
        },
        {
          "@type": "PropertyValue",
          "name": "Cash Tendered",
          "value": "50000",
          "unitText": "IDR"
        },
        {
          "@type": "PropertyValue",
          "name": "Change Due",
          "value": "16000",
          "unitText": "IDR"
        }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "34000",
      "priceCurrency": "IDR",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 2,
        "unitText": "item"
      },
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "17000",
        "priceCurrency": "IDR",
        "referenceQuantity": {
          "@type": "QuantitativeValue",
          "value": 1,
          "unitText": "item"
        }
      },
      "itemOffered": {
        "@id": "#product-1"
      }
    },
    {
      "@id": "#product-1",
      "@type": "Product",
      "name": "[ERROR:UNCERTAIN] annes tripple cheese"
    }
  ]
}
