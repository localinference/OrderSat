{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#order",
      "@type": "Order",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        }
      ],
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "price": "14000"
      }
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "14000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-1"
      }
    },
    {
      "@id": "#product-1",
      "@type": "Product",
      "name": "Passionfruit Mojito"
    }
  ]
}
