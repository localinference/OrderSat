{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#customer",
      "@type": "Organization",
      "name": "Lino-Delicateses",
      "identifier": {
        "@type": "PropertyValue",
        "name": "Customer ID",
        "value": "linod"
      }
    },
    {
      "@id": "#shipper",
      "@type": "Organization",
      "name": "Speedy Express",
      "identifier": {
        "@type": "PropertyValue",
        "name": "Shipper ID",
        "value": "1"
      }
    },
    {
      "@id": "#delivery",
      "@type": "ParcelDelivery",
      "deliveryAddress": {
        "@type": "PostalAddress",
        "streetAddress": "Ave. 5 de Mayo Porlamar",
        "addressLocality": "I. de Margarita",
        "addressRegion": "South America",
        "addressCountry": "Venezuela",
        "postalCode": "4980"
      },
      "provider": {
        "@id": "#shipper"
      }
    },
    {
      "@id": "#order",
      "@type": "Order",
      "orderNumber": "10405",
      "orderDate": "2017-01-06",
      "customer": {
        "@id": "#customer"
      },
      "orderDelivery": {
        "@id": "#delivery"
      },
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        }
      ],
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "price": "400.0"
      },
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Employee Name",
          "value": "Nancy Davolio"
        },
        {
          "@type": "PropertyValue",
          "name": "Shipped Date",
          "value": "2017-01-22"
        }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "400.0",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 50,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-1"
      },
      "priceSpecification": {
        "@type": "UnitPriceSpecification",
        "price": "8.0",
        "referenceQuantity": {
          "@type": "QuantitativeValue",
          "value": 1,
          "unitText": "item"
        }
      }
    },
    {
      "@id": "#product-1",
