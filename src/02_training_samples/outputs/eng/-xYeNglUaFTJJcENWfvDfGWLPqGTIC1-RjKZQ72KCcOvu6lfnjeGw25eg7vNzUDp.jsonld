{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#order",
      "@type": "Order",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        },
        {
          "@id": "#offer-2"
        },
        {
          "@id": "#offer-3"
        }
      ],
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "price": "35000"
      }
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "25000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-1"
      }
    },
    {
      "@id": "#product-1",
      "@type": "Product",
      "name": "specialty combo"
    },
    {
      "@id": "#offer-2",
      "@type": "Offer",
      "price": "5000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-2"
      }
    },
    {
      "@id": "#product-2",
      "@type": "Product",
      "name": "[ERROR:UNCERTAIN] lemonader"
    },
    {
      "@id": "#offer-3",
      "@type": "Offer",
      "price": "5000",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-3"
      }
    },
    {
      "@id": "#product-3",
      "@type": "Product",
      "name": "ades 300ml"
    }
  ]
}
