{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@id": "#order",
      "@type": "Order",
      "priceCurrency": "IDR",
      "paymentMethod": "https://schema.org/Cash",
      "paymentStatus": "https://schema.org/PaymentComplete",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        },
        {
          "@id": "#offer-2"
        }
      ],
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "priceCurrency": "IDR",
        "price": "22000"
      },
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Cash Tendered",
          "value": "22000",
          "unitText": "IDR"
        },
        {
          "@type": "PropertyValue",
          "name": "Change",
          "value": "0",
          "unitText": "IDR"
        }
      ]
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "12000",
      "priceCurrency": "IDR",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-1"
      }
    },
    {
      "@id": "#product-1",
      "@type": "Product",
      "name": "[ERROR:UNCERTAIN] elephant rerd bean"
    },
    {
      "@id": "#offer-2",
      "@type": "Offer",
      "price": "10000",
      "priceCurrency": "IDR",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 1,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-2"
      }
    },
    {
      "@id": "#product-2",
      "@type": "Product",
      "name": "[ERROR:UNCERTAIN] chapsal twister donnut"
    }
  ]
}
