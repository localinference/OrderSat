      "name": "Old World Delicatessen",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "2743 Bering St",
        "addressLocality": "Anchorage",
        "postalCode": "99508",
        "addressCountry": "USA"
      }
    },
    {
      "@id": "#order",
      "@type": "Order",
      "seller": {
        "@id": "#carrier"
      },
      "customer": {
        "@id": "#customer"
      },
      "orderNumber": "10441",
      "orderDate": "2017-02-10",
      "priceCurrency": "USD",
      "acceptedOffer": [
        {
          "@id": "#offer-1"
        }
      ],
      "orderDelivery": {
        "@id": "#delivery"
      },
      "totalPaymentDue": {
        "@type": "PriceSpecification",
        "priceCurrency": "USD",
        "price": "1755.00"
      },
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Customer ID",
          "value": "OLDWO"
        },
        {
          "@type": "PropertyValue",
          "name": "Employee Name",
          "value": "Janet Leverling"
        },
        {
          "@type": "PropertyValue",
          "name": "Shipper ID",
          "value": "2"
        }
      ]
    },
    {
      "@id": "#delivery",
      "@type": "ParcelDelivery",
      "carrier": {
        "@id": "#carrier"
      },
      "deliveryAddress": {
        "@type": "PostalAddress",
        "streetAddress": "2743 Bering St",
        "addressLocality": "Anchorage",
        "postalCode": "99508",
        "addressCountry": "USA"
      },
      "expectedArrivalUntil": "2017-03-14"
    },
    {
      "@id": "#offer-1",
      "@type": "Offer",
      "price": "1755.00",
      "priceCurrency": "USD",
      "eligibleQuantity": {
        "@type": "QuantitativeValue",
        "value": 50,
        "unitText": "item"
      },
      "itemOffered": {
        "@id": "#product-1"
      },
      "seller": {
        "@id": "#carrier"
      }
    },
    {
      "@id": "#product-1",
      "@type": "Product",
      "name": "Schoggi Schokolade"
    }
  ]
